# OpenID Connect / Salesforce SSO
# Copy to .env and replace placeholders. Never commit .env or real secrets.

VITE_SSO_BASE_URL=https://your-org.sandbox.my.site.com
VITE_SSO_APP_ID=your_salesforce_connected_app_consumer_key
VITE_SSO_REDIRECT_URI=http://localhost:3000

# Required for token exchange (dev server proxy). Use the consumer secret from the Connected App.
VITE_SSO_APP_SECRET=your_salesforce_connected_app_consumer_secret
SSO_APP_SECRET=your_salesforce_connected_app_consumer_secret
